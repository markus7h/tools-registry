# Registry-Server: liefert das scripts/-Verzeichnis per HTTP aus (Teil A).
# scripts/ wird per Bind-Mount eingehängt (siehe docker-compose.registry.yml),
# damit Script-Änderungen ohne Image-Rebuild live ausgeliefert werden.
FROM node:22-slim

WORKDIR /app

COPY package.json package-lock.json ./
RUN npm ci --omit=dev

COPY dist ./dist

ENV TOOLS_SCRIPTS_DIR=/app/scripts
ENV PORT=3457
ENV HOST=0.0.0.0

EXPOSE 3457

CMD ["node", "dist/registry-server.js"]
